{
  "manifest_version": 3,
  "name": "NorskTale",
  "version": "1.2",
  "description": "Norwegian spelling and grammar checking — works with Google Docs, textareas, and contenteditable",
  "permissions": ["nativeMessaging", "alarms"],
  "content_scripts": [
    {
      "matches": ["*://docs.google.com/document/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://docs.google.com/document/*"],
      "js": ["gdocs-inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {}
}
