{
  "manifest_version": 3,
  "name": "NorskTale",
  "version": "1.1",
  "description": "Sends textarea text and cursor position to NorskTale for Norwegian spelling and grammar checking",
  "permissions": ["nativeMessaging", "alarms"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {}
}
